{
  "rewrites": [
    { "source": "/admin", "destination": "/admin" },
    { "source": "/watchlist", "destination": "/watchlist" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}